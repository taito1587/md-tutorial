# --- AMBER MD outputs ---------------------------------------------------------
# These are generated by tleap / sander / cpptraj when the learner runs the
# tutorial. They are large and reproducible from the input files, so we don't
# track them in git.

# Topology and coordinate files produced by tleap
*.parm7
*.rst7
*.prmtop
*.inpcrd

# sander / pmemd outputs
*.out
*.nc
*.ncrst
*.mdcrd
*.mdvel
*.mdfrc
mdinfo
mdcrd
restrt

# tleap log
leap.log
leap.out

# cpptraj / analysis outputs
*.rms
*.dat
summary.*

# Plot files
*.png
*.pdf
*.eps

# --- Tutorial workspace/ — learner sandbox ------------------------------------
# Each tutorial step has a workspace/ directory where the learner runs commands.
# Anything created there (subdirectories, output files, edited inputs, notes)
# is the learner's own work and should NOT be committed back to the tutorial
# repo. Only the workspace/README.md scaffolding stays under version control.
*/workspace/*
!*/workspace/README.md

# --- Nix ----------------------------------------------------------------------
result
result-*

# --- Conda / micromamba env (created on first `nix develop`) ------------------
# These directories hold ~3 GB of AmberTools binaries, regenerable from
# environment.yml. Never commit them.
.mamba-env/
.mamba-root/

# --- direnv -------------------------------------------------------------------
.direnv/

# --- editor / OS -------------------------------------------------------------
.DS_Store
*.swp
*~
.idea/
.vscode/
